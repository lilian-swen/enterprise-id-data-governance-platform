package com.idgovern.service;


import com.fasterxml.jackson.core.type.TypeReference;
import com.idgovern.util.JsonMapper;
import jakarta.annotation.Resource;
import lombok.extern.slf4j.Slf4j;
import org.springframework.data.redis.core.StringRedisTemplate;
import org.springframework.stereotype.Service;

import java.util.List;
import java.util.concurrent.TimeUnit;

// 2/28/2026
// TODO : ADD code comments and figure out how to use it , which package I should put this class

@Service
@Slf4j
public class RedisService {

    @Resource
    private StringRedisTemplate stringRedisTemplate;

    /**
     * Set a value with an expiration time (Cache-Aside)
     */
    public void setEx(String key, String value, long timeoutSeconds) {
        stringRedisTemplate.opsForValue().set(key, value, timeoutSeconds, TimeUnit.SECONDS);
    }

    /**
     * Retrieve a simple String value
     */
    public String get(String key) {
        return stringRedisTemplate.opsForValue().get(key);
    }

    /**
     * Retrieve and Deserialize a List or Object from JSON
     * Usage: getList("user_acl_1", new TypeReference<List<SysAcl>>(){})
     */
    public <T> T get(String key, TypeReference<T> typeReference) {
        String value = get(key);
        if (value == null) {
            return null;
        }
        return JsonMapper.string2Obj(value, typeReference);
    }

    /**
     * Delete a key (Crucial for Cache Invalidation)
     */
    public void delete(String key) {
        stringRedisTemplate.delete(key);
    }


    public <T> List<T> getList(String key, Class<T> clazz) {
        String value = get(key);
        if (value == null) {
            return null;
        }
        // This uses the JsonMapper to convert the JSON string back into a List
        return JsonMapper.string2Obj(value, new TypeReference<List<T>>() {});
    }
}